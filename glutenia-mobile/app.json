{
  "expo": {
    "name": "Glutenia",
    "slug": "glutenia-mobile",
    "version": "1.0.8",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "glutenia",
    "userInterfaceStyle": "light",
    "jsEngine": "jsc",
    "newArchEnabled": false,
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.glutenia.mobile",
      "versionCode": 9,
      "jsEngine": "jsc",
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F8F5F0"
      }
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8F5F0"
    },
    "plugins": [
      "expo-asset",
      "expo-font"
    ],
    "extra": {
      "apiBaseUrl": "https://glutenia.onrender.com/api"
    }
  }
}
